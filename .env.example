# Copie este arquivo para .env e preencha com suas chaves reais
# NUNCA commite o arquivo .env

# HubSpot Private App Token
HUBSPOT_API_KEY=seu_token_aqui

# OpenAI API Key
OPENAI_API_KEY=sua_chave_aqui

# E-mail da gestora de CS (para alertas futuros)
GERENTE_CS_EMAIL=seu_email@twygo.com

# SMTP (opcional — para envio de alertas por e-mail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
